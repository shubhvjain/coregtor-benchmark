Bootstrap: docker
From: bioconductor/bioconductor_docker:RELEASE_3_16

%post
    # Prevent interactive prompts during package installations
    export DEBIAN_FRONTEND=noninteractive

    # Install general CRAN packages (Added arrow and jsonlite for file parsing)
    R -e "install.packages(c('reticulate', 'arrow', 'jsonlite'), repos='https://cloud.r-project.org')"

    # Install Python deps via pip (Added pyarrow for fast DataFrame serialization)
    python3 -m pip install --no-cache-dir \
        pandas \
        pyarrow \
        python-dotenv \
        pathlib
    rm -rf /root/.cache/pip/*

    # Install CoRegNet and RTNDuals together
    R -e "BiocManager::install(c('CoRegNet', 'RTNDuals'), update = FALSE, ask = FALSE)"

    # Set reticulate to system Python inside the R environment configuration
    echo "Sys.setenv(RETICULATE_PYTHON = '/usr/bin/python3')" >> /usr/local/lib/R/etc/Rprofile.site

%environment
    # Set environment variables for runtime
    export RETICULATE_PYTHON=/usr/bin/python3

%runscript
    # Overridden to use python3 since Python is now orchestrating the pipeline
    exec python3 "$@"