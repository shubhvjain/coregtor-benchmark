{
  "id": "ps_amy",
  "about": "To run CoRegTor on a simple dataset",

  "dataset": {
    "name": "AMY",
    "path": "$DATA_PATH/amygdala/gene_tpm_v10_brain_amygdala.gct",
    "type": "gct",
    "convert_gene_names": true
  },

  "sources": {
    "type": "tf",
    "top_expressed_n": 1600
  },
  "targets": {
    "type": "pc_only",
    "top_expressed_n": 500
  },
  "ensemble_model": {
    "method": "rf",
    "options": {
      "max_depth": 5,
      "n_jobs": -1,
      "n_estimators": 1000,
      "random_state": 120
    }
  },
  "context_comparison": {
    "methods": [
      "cosine_distance",
      "euclidean_distance",
      "manhattan_distance",
      "weighted_jaccard",
      "jensenshannon_distance",
      "canberra_distance",
      "sorensen_distance",
      "chebyshev_distance"
    ]
  },
  "clustering": [
    {
      "id": "c1",
