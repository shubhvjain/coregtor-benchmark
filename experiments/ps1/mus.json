{
  "id": "ps1_mus",
  "about": "To run CoRegTor on a simple dataset",

  "dataset": {
    "name": "HYP",
    "path": "$DATA_PATH/muscle_skeletal/gene_tpm_v11_muscle_skeletal.gct",
    "type": "gct",
    "convert_gene_names": true
  },

  "sources": {
    "type": "tf",
    "top_expressed_n": 1600
  },
  "targets": {
    "type": "pc_only",
    "top_expressed_n": 500
  },
  "ensemble_model": {
    "method": "rf",
    "options": {
      "max_depth": 5,
      "n_jobs": -1,
      "n_estimators": 1000,
      "random_state": 120
    }
  },
  "context_comparison": {
    "methods": [
      "cosine_distance",
      "euclidean_distance",
      "weighted_jaccard",
      "wasserstein_distance"
    ]
  },
  "clustering": [
